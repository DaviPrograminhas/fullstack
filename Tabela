<!DOCTYPE html>
<html>
<head>
<link rel="stylesheet" href="style.css">
</head>

<body>

<table>
    <thead>
        <tr>
            <th>Nome</th>
            <th>Idade</th>
            <th>Cidade</th>
        </tr>
    </thead>

    <tbody>
        <tr>
            <td>Davi</td>
            <td>17</td>
            <td>São Paulo</td>
        </tr>

        <tr>
            <td>Lucas</td>
            <td>18</td>
            <td>Campinas</td>
        </tr>

        <tr>
            <td>Ana</td>
            <td>17</td>
            <td>Santos</td>
        </tr>
    </tbody>
</table>

</body>
</html>


body{
    font-family: Arial;
    background-color: #f4f4f4;
}

table{
    width: 60%;
    margin: 50px auto;
    border-collapse: collapse;
    background-color: white;
    box-shadow: 0px 0px 10px rgba(0,0,0,0.1);
}

th, td{
    padding: 12px;
    text-align: center;
}

th{
    background-color: #4CAF50;
    color: white;
}

tr:nth-child(even){
    background-color: #f2f2f2;
}

tr:hover{
    background-color: #ddd;
}
